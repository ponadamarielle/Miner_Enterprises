    "version": "0.2.0",
    "configurations": [

        {
            "name": "Miner Enterprise (Web)",
            "cwd": "app",
            "request": "launch",
            "type": "dart",
            "args": [
                "-d",
                "chrome",
                "--web-port=62208"
            ]
        },
        {
            "name": "app (profile mode)",
            "cwd": "app",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "app (release mode)",
            "cwd": "app",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        },
        {
            "name": "backend",
            "cwd": "backend",
            "request": "launch",
            "type": "dart"
        }
    ]
}